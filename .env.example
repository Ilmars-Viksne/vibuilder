# NVIDIA NIM API Key
NIM_API_KEY=your_nvidia_nim_key_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_key_here

# Google AI Studio / Gemini API Key
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# LM Studio (Usually local, no key needed, but placeholder if required)
LMSTUDIO_API_KEY=lm-studio

# Optional: Set the default provider here instead of config.yaml
# DEFAULT_PROVIDER=nim
